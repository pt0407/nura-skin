{
  "name": "nura",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "On-device AI skin & hair analysis. Your face never leaves your device.",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently \"npm run dev\" \"npm run server\"",
    "server": "cd server && npm run dev",
    "db:up": "docker-compose up -d",
    "db:setup": "node scripts/setup-db.js",
    "db:down": "docker-compose down",
    "db:remote": "node scripts/provision-neon.js",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "framer-motion": "^11.3.19",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^10.0.3",
    "neonctl": "^2.26.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.1"
  }
}
